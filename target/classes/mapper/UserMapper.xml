<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.chatting_in_web.dao.UserDao">

    <select id="findUser" resultType="com.example.chatting_in_web.entity.LoginUser">
        select user.username,user.phone_number,user.password from user where
        phone_number = #{phone_number}
    </select>

    <select id="findUsername" parameterType="java.lang.String" resultType="java.lang.String">
        select user.username from user where
            phone_number = #{phone_number}
    </select>

    <insert id="addUser" parameterType="com.example.chatting_in_web.entity.User">
        insert into user (username,sex,phone_number,email,password) value (
            #{username},#{sex},#{phone_number},#{email},#{password}
        )
    </insert>
</mapper>